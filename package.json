{
  "name": "liturgical-armenian-translit",
  "version": "1.0.0",
  "description": "Classical Armenian (Grabar) to English transliteration library based on Western Armenian liturgical pronunciation",
  "main": "src/translit.js",
  "scripts": {
    "analyze": "node analyze.js",
    "audit:dictionary": "node audit-dictionary.js",
    "build:dictionary": "node build-dict.js",
    "debug": "node debug.js",
    "demo": "node demo.js",
    "metrics": "node report-metrics.js",
    "test": "node --test test/*.test.js",
    "test:corpus": "node test-paragraph.js",
    "translit": "node -e \"const{transliterate}=require('./src/translit');console.log(transliterate(process.argv[1]))\" --"
  },
  "keywords": [
    "armenian",
    "transliteration",
    "grabar",
    "liturgy",
    "classical-armenian",
    "western-armenian",
    "church-slavonic"
  ],
  "author": "Fr. Mesrop Ash \u003cpastor@stjohnarmenianchurch.com\u003e",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stjohnarmenianchurch/liturgical-armenian-translit-js.git"
  },
  "files": [
    "src/translit.js",
    "src/translit.mjs",
    "src/dictionary.json",
    "src/compact-dictionary.json",
    "src/exact-dictionary.json",
    "src/dictionary-overrides.json",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./src/translit.mjs",
      "require": "./src/translit.js"
    },
    "./src/dictionary.json": "./src/dictionary.json"
  }
}
